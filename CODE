# HAZARD MANAGER — *** SHOCKWAVE FIX: KILLS DURING ENTIRE EXPANSION ***
# ─────────────────────────────────────────────────────────────────────────────

class HazardManager:
    def __init__(self, config, rng):
        self.config=config; self.rng=rng
        self.fireballs: List[Fireball]=[]
        self.spinning_lasers: List[SpinningLaser]=[]
        self.death_walls: List[DeathWall]=[]
        self.shockwaves: List[Shockwave]=[]
        self.meteors: List[Meteor]=[]
        self.spikes: List[Spike]=[]
        self.lava_zones: List[LavaZone]=[]
        self.vortices: List[Vortex]=[]
        self.sigma_stares: List[SigmaStare]=[]
        self.ratio_beams: List[RatioBeam]=[]
        self.npc_freezes: List[NpcFreeze]=[]
        self.backrooms_holes: List[BackroomsHole]=[]
        self.frozen_ball_ids: Set[int]=set()
        self.black_holes: List[BlackHoleHazard]=[]
        self.lightning_bolts: List[LightningBolt]=[]
        self.toxic_clouds: List[ToxicCloud]=[]
        self.orbital_lasers: List[OrbitalLaser]=[]
        self.cracks: List[Crack]=[]

    def update(self, t, frame, arena):
        ax1,ay1,ax2,ay2=arena
        for fb in self.fireballs:
            fb.trail.append((fb.x,fb.y))
            if len(fb.trail)>12: fb.trail.pop(0)
            fb.x+=fb.vx; fb.y+=fb.vy
            if fb.x-fb.radius<ax1: fb.x=ax1+fb.radius; fb.vx=abs(fb.vx)
            if fb.x+fb.radius>ax2: fb.x=ax2-fb.radius; fb.vx=-abs(fb.vx)
            if fb.y-fb.radius<ay1: fb.y=ay1+fb.radius; fb.vy=abs(fb.vy)
            if fb.y+fb.radius>ay2: fb.y=ay2-fb.radius; fb.vy=-abs(fb.vy)
            fb.lifetime-=1.0/self.config.fps
        self.fireballs=[f for f in self.fireballs if f.lifetime>0]

        for sl in self.spinning_lasers:
            sl.angle+=sl.speed
            if sl.warmup_frames>0: sl.warmup_frames-=1
            sl.lifetime_frames-=1
        self.spinning_lasers=[sl for sl in self.spinning_lasers if sl.lifetime_frames>0]

        for dw in self.death_walls:
            if dw.warmup_frames>0: dw.warmup_frames-=1
            if dw.retreating: dw.position=max(0.0,dw.position-dw.speed)
            elif dw.position<dw.max_position: dw.position+=dw.speed
            dw.lifetime_frames-=1
            if dw.lifetime_frames<=0 and not dw.retreating: dw.retreating=True
        self.death_walls=[dw for dw in self.death_walls if not dw.retreating or dw.position>0]

        for sw in self.shockwaves:
            if not sw.done:
                sw.current_radius+=sw.speed
                if sw.current_radius>=sw.max_radius: sw.done=True
        self.shockwaves=[s for s in self.shockwaves if not s.done]

        for m_obj in self.meteors:
            if not m_obj.exploded:
                m_obj.current_y+=m_obj.speed
                if m_obj.current_y>=m_obj.target_y: m_obj.exploded=True; m_obj.explosion_frame=frame
            else:
                age=frame-m_obj.explosion_frame
                expand_frames=15
                if age<=expand_frames:
                    m_obj.current_blast_radius=m_obj.blast_radius*((age+1)/expand_frames)
        self.meteors=[m_obj for m_obj in self.meteors if not m_obj.exploded or frame-m_obj.explosion_frame<30]

        for sp in self.spikes:
            sp.pulse_phase+=0.1
            if sp.warmup_frames>0: sp.warmup_frames-=1

        for lz in self.lava_zones:
            if lz.warmup_frames>0: lz.warmup_frames-=1
            if lz.thickness<lz.max_thickness: lz.thickness+=lz.grow_speed

        for v in self.vortices:
            v.rotation+=0.08; v.lifetime_frames-=1
        self.vortices=[v for v in self.vortices if v.lifetime_frames>0]

        for ss in self.sigma_stares:
            ss.pulse+=0.15
            if ss.warmup_frames>0: ss.warmup_frames-=1
            else:
                ss.active_frames-=1
                if ss.active_frames<=0: ss.done=True
        self.sigma_stares=[s for s in self.sigma_stares if not s.done]

        for rb in self.ratio_beams:
            if not rb.done:
                rb.position+=rb.speed
                if rb.position>=rb.end_position: rb.done=True
        self.ratio_beams=[r for r in self.ratio_beams if not r.done]

        for nf in self.npc_freezes:
            if nf.phase=="warmup":
                if nf.warmup_frames>0: nf.warmup_frames-=1
                else: nf.phase="frozen"
            elif nf.phase=="frozen":
                if nf.freeze_frames>0: nf.freeze_frames-=1
                else: nf.phase="shatter"
            elif nf.phase=="shatter": nf.done=True
        self.npc_freezes=[n for n in self.npc_freezes if not n.done]
        self.frozen_ball_ids={bid for nf in self.npc_freezes if nf.phase in ("warmup","frozen") for bid in nf.frozen_ids}

        for bh in self.backrooms_holes:
            if bh.warmup_frames>0: bh.warmup_frames-=1
            else: bh.lifetime_frames-=1
            if bh.lifetime_frames<=0: bh.done=True
        self.backrooms_holes=[b for b in self.backrooms_holes if not b.done]

        if len(self.spikes)>35: self.spikes=self.spikes[-30:]
        if len(self.fireballs)>10: self.fireballs=self.fireballs[-8:]
        if len(self.spinning_lasers)>3: self.spinning_lasers=self.spinning_lasers[-3:]
        if len(self.death_walls)>4: self.death_walls=self.death_walls[-4:]
        if len(self.vortices)>3: self.vortices=self.vortices[-3:]

        for bh in self.black_holes:
            bh.frame += 1
            bh.lifetime_frames -= 1
        self.black_holes = [bh for bh in self.black_holes if bh.lifetime_frames > 0]

        for lb in self.lightning_bolts:
            if lb.warning_frames > 0:
                lb.warning_frames -= 1
                if lb.warning_frames == 0:
                    lb.active = True
                    lb.strike_frame = frame
            if lb.active:
                lb.lifetime -= 1
        self.lightning_bolts = [lb for lb in self.lightning_bolts
                                 if lb.warning_frames > 0 or lb.lifetime > 0]

        for tc in self.toxic_clouds:
            tc.frame += 1
            tc.lifetime_frames -= 1
            if tc.radius < tc.max_radius:
                tc.radius += tc.expand_speed
        self.toxic_clouds = [tc for tc in self.toxic_clouds if tc.lifetime_frames > 0]

        for ol in self.orbital_lasers:
            if ol.warning_frames > 0:
                ol.warning_frames -= 1
                if ol.warning_frames == 0:
                    ol.active = True
            if ol.active and not ol.done:
                ol.current_pos += ol.speed
                if ol.current_pos >= ol.end_pos:
                    ol.done = True
        self.orbital_lasers = [ol for ol in self.orbital_lasers if not ol.done]

        for cr in self.cracks:
            cr.frame += 1
            cr.lifetime_frames -= 1
        self.cracks = [cr for cr in self.cracks if cr.lifetime_frames > 0]

    def check_ball_death(self, ball, frame, arena):
        """
        Visual-gameplay sync: kills happen exactly when the visual hazard reaches a ball.
        - Shockwave: thin ring band matched to visual ring (kill_thickness = thickness/2)
        - Meteor: expanding blast radius from 0 to blast_radius over 15 frames
        - Laser: kill_radius = thickness/2 + ball_radius (matches beam visuals)
        - All other hazards: kill zones match visual representations exactly
        """
        if not ball.alive or ball.invincible_timer>0: return False
        bx,by,br=ball.x,ball.y,ball.radius
        ax1,ay1,ax2,ay2=arena

        for fb in self.fireballs:
            if math.hypot(bx-fb.x,by-fb.y)<fb.radius+br: return True

        for sl in self.spinning_lasers:
            if sl.warmup_frames>0: continue
            for arm_i in range(sl.arms):
                arm_angle=sl.angle+arm_i*(2*math.pi/sl.arms)
                ex=sl.cx+math.cos(arm_angle)*sl.length; ey=sl.cy+math.sin(arm_angle)*sl.length
                if self._point_line_dist(bx,by,sl.cx,sl.cy,ex,ey)<sl.kill_radius+br: return True

        for dw in self.death_walls:
            if dw.warmup_frames>0 or dw.retreating or dw.position<=0: continue
            if dw.side=="left" and bx-br<ax1+dw.position: return True
            if dw.side=="right" and bx+br>ax2-dw.position: return True
            if dw.side=="top" and by-br<ay1+dw.position: return True
            if dw.side=="bottom" and by+br>ay2-dw.position: return True

        # *** SHOCKWAVE — REAL-TIME PROGRESSIVE KILL ***
        # The visual ring is drawn centered on current_radius with width = thickness.
        # A ball dies precisely when the expanding visual ring sweeps over it:
        # abs(dist - current_radius) < kill_thickness + ball_radius
        # where kill_thickness = thickness/2 so the band exactly matches the visual ring.
        for sw in self.shockwaves:
            dist = math.hypot(bx - sw.cx, by - sw.cy)
            if abs(dist - sw.current_radius) < sw.kill_thickness + br:
                return True

        for m_obj in self.meteors:
            if m_obj.exploded and m_obj.current_blast_radius>0:
                if math.hypot(bx-m_obj.target_x,by-m_obj.target_y)<m_obj.current_blast_radius+br: return True

        for sp in self.spikes:
            if sp.warmup_frames>0: continue
            pulse=1.0+0.15*math.sin(sp.pulse_phase)
            if math.hypot(bx-sp.x,by-sp.y)<sp.radius*pulse+br: return True

        for lz in self.lava_zones:
            if lz.warmup_frames>0: continue
            th=lz.thickness
            if th<=0: continue
            if lz.side=="bottom" and by+br>ay2-th: return True
            if lz.side=="top" and by-br<ay1+th: return True
            if lz.side=="left" and bx-br<ax1+th: return True
            if lz.side=="right" and bx+br>ax2-th: return True

        for v in self.vortices:
            if math.hypot(bx-v.x,by-v.y)<v.kill_radius+br: return True

        for ss in self.sigma_stares:
            if ss.warmup_frames>0: continue
            dx=bx-ss.x; dy=by-ss.y; dist=math.hypot(dx,dy)
            if dist<ss.cone_range:
                ball_angle=math.atan2(dy,dx)
                diff=abs((ball_angle-ss.angle+math.pi)%(2*math.pi)-math.pi)
                if diff<ss.cone_half: return True

        for rb in self.ratio_beams:
            if rb.done: continue
            if rb.axis=="h":
                if abs(by-rb.position)<rb.width//2+br: return True
            else:
                if abs(bx-rb.position)<rb.width//2+br: return True

        for nf in self.npc_freezes:
            if nf.phase=="shatter" and ball.id in nf.frozen_ids: return True

        for bh in self.backrooms_holes:
            if bh.warmup_frames>0: continue
            if (bx-br<bh.x+bh.w and bx+br>bh.x and by-br<bh.y+bh.h and by+br>bh.y): return True

        for bhz in self.black_holes:
            if math.hypot(bx-bhz.cx, by-bhz.cy) < bhz.kill_radius + br: return True

        for lb in self.lightning_bolts:
            if lb.active and lb.strike_frame == frame:
                if math.hypot(bx-lb.target_x, by-lb.target_y) < lb.kill_radius + br: return True

        for cr in self.cracks:
            if HazardManager._point_line_dist(bx, by, cr.x1, cr.y1, cr.x2, cr.y2) < cr.kill_width + br: return True

        for ol in self.orbital_lasers:
            if ol.active and not ol.done:
                hw = ol.width // 2
                if ol.direction == "h":
                    if abs(by - ol.current_pos) < hw + br: return True
                else:
                    if abs(bx - ol.current_pos) < hw + br: return True

        return False

    def apply_vortex_force(self, ball):
        for v in self.vortices:
            dx=v.x-ball.x; dy=v.y-ball.y; dist=math.hypot(dx,dy)
            if 0<dist<v.radius:
                force=v.strength*(1.0-dist/v.radius)/max(dist,1.0)
                ball.vx+=dx*force*0.04; ball.vy+=dy*force*0.04
        for bhz in self.black_holes:
            dx=bhz.cx-ball.x; dy=bhz.cy-ball.y; dist=math.hypot(dx,dy)
            if 0<dist<bhz.radius:
                force=bhz.strength*bhz.radius/(dist*dist+10)
                ball.vx+=dx/dist*force*0.15; ball.vy+=dy/dist*force*0.15

    @staticmethod
    def _point_line_dist(px,py,x1,y1,x2,y2):
        dx,dy=x2-x1,y2-y1
        if dx==0 and dy==0: return math.hypot(px-x1,py-y1)
        t=max(0,min(1,((px-x1)*dx+(py-y1)*dy)/(dx*dx+dy*dy)))
        return math.hypot(px-(x1+t*dx),py-(y1+t*dy))

    def update_toxic_exposure(self, balls):
        """Track how long each ball has been inside a toxic cloud."""
        alive_ids = {b.id for b in balls if b.alive}
        for tc in self.toxic_clouds:
            for bid in list(tc.ball_exposure.keys()):
                if bid not in alive_ids:
                    del tc.ball_exposure[bid]
            for b in balls:
                if not b.alive: continue
                dist = math.hypot(b.x - tc.cx, b.y - tc.cy)
                if dist < tc.radius + b.radius:
                    tc.ball_exposure[b.id] = tc.ball_exposure.get(b.id, 0) + 1
                else:
                    tc.ball_exposure[b.id] = max(0, tc.ball_exposure.get(b.id, 0) - 2)

    def check_toxic_death(self, ball):
        """Returns True if ball has been in toxic cloud for 60+ frames."""
        if not ball.alive or ball.invincible_timer > 0: return False
        for tc in self.toxic_clouds:
            if tc.ball_exposure.get(ball.id, 0) >= 60: return True
        return False

