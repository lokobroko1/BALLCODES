    hazards.meteors=[Meteor(target_x=tx,target_y=ty,current_y=cy_m,x=mx,radius=r,blast_radius=br,exploded=ex,explosion_frame=ef,current_blast_radius=cbr) for tx,ty,cy_m,mx,r,br,ex,ef,cbr in snap["meteors"]]
    hazards.spikes=[Spike(x=x,y=y,radius=r,pulse_phase=pp,warmup_frames=wf) for x,y,r,pp,wf in snap["spikes"]]
    hazards.lava_zones=[LavaZone(side=s,thickness=th,warmup_frames=wf) for s,th,wf in snap["lava_zones"]]
    hazards.vortices=[Vortex(x=x,y=y,radius=r,rotation=rot,kill_radius=kr) for x,y,r,rot,kr in snap["vortices"]]
    hazards.sigma_stares=[SigmaStare(x=x,y=y,angle=a,warmup_frames=wf,active_frames=af,pulse=p) for x,y,a,wf,af,p in snap.get("sigma_stares",[])]
    hazards.ratio_beams=[RatioBeam(axis=ax,position=pos,speed=sp,end_position=ep,width=w,color=c) for ax,pos,sp,ep,w,c in snap.get("ratio_beams",[])]
    hazards.npc_freezes=[NpcFreeze(frozen_ids=set(fids),warmup_frames=wf,freeze_frames=ff,phase=ph) for fids,wf,ff,ph in snap.get("npc_freezes",[])]
    hazards.backrooms_holes=[BackroomsHole(x=x,y=y,w=w,h=h,warmup_frames=wf,lifetime_frames=lf) for x,y,w,h,wf,lf in snap.get("backrooms_holes",[])]
    hazards.frozen_ball_ids={bid for nf in hazards.npc_freezes if nf.phase in ("warmup","frozen") for bid in nf.frozen_ids}
    hazards.black_holes=[BlackHoleHazard(cx=cx,cy=cy,strength=st,radius=r,kill_radius=kr,lifetime_frames=lf) for cx,cy,st,r,kr,lf in snap.get("black_holes",[])]
    hazards.lightning_bolts=[LightningBolt(target_x=tx,target_y=ty,warning_frames=wf,active=ac,strike_frame=sf,lifetime=lf,kill_radius=kr) for tx,ty,wf,ac,sf,lf,kr in snap.get("lightning_bolts",[])]
    hazards.toxic_clouds=[ToxicCloud(cx=cx,cy=cy,radius=r,max_radius=mr,expand_speed=es,lifetime_frames=lf,ball_exposure=dict(be)) for cx,cy,r,mr,es,lf,be in snap.get("toxic_clouds",[])]
    hazards.orbital_lasers=[OrbitalLaser(direction=d,start_pos=sp,end_pos=ep,current_pos=cp,speed=spd,width=w,warning_frames=wf,active=ac,done=dn) for d,sp,ep,cp,spd,w,wf,ac,dn in snap.get("orbital_lasers",[])]
    hazards.cracks=[Crack(x1=x1,y1=y1,x2=x2,y2=y2,kill_width=kw,lifetime_frames=lf) for x1,y1,x2,y2,kw,lf in snap.get("cracks",[])]

