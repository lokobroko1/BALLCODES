def _avatar_meltdown(rng, size):
    """Face that looks like it's melting — droopy eyes, dripping colors."""
    h = rng.random()
    bg = _hsv(h, 0.7, 0.6)
    img = Image.new("RGBA", (size, size), (0,0,0,0))
    draw = ImageDraw.Draw(img)
    draw.ellipse([0, 0, size-1, size-1], fill=bg)
    m = size // 2
    drip_col = _hsv((h + 0.3) % 1.0, 0.9, 0.95)
    for _ in range(rng.randint(5, 12)):
        dx = rng.randint(m - size//3, m + size//3)
        dy_start = rng.randint(5, size//3)
        dy_end = rng.randint(size//2, size - 5)
        dw = rng.randint(2, 6)
        draw.line([(dx, dy_start), (dx, dy_end)], fill=drip_col, width=dw)
        draw.ellipse([dx-dw, dy_end-dw, dx+dw, dy_end+dw], fill=drip_col)
    left_ey = m - int(size * 0.12) + rng.randint(-5, 5)
    right_ey = m - int(size * 0.12) + rng.randint(-5, 5)
    er = int(size * rng.uniform(0.05, 0.09))
    draw.ellipse([m - int(size*0.17) - er, left_ey - er,
                  m - int(size*0.17) + er, left_ey + er + rng.randint(2,8)],
                 fill=(30, 30, 30, 255))
    draw.ellipse([m + int(size*0.17) - er, right_ey - er,
                  m + int(size*0.17) + er, right_ey + er],
                 fill=(30, 30, 30, 255))
    pts = []
    mx_start = m - int(size * 0.2)
    mx_end = m + int(size * 0.2)
    my_base = m + int(size * 0.15)
    for i in range(15):
        xp = mx_start + (mx_end - mx_start) * i // 14
        yp = my_base + int(rng.uniform(-6, 6) * math.sin(i * 0.8))
