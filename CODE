        if winner_time is not None: race_end=int(winner_time*sr)
        else: race_end=int((total_duration-5.0)*sr)
        race_end=min(race_end,total_samples)

        # ── RANDOM SONG SELECTION (~16.67% each, 6 songs) ────────────────────
        song_fns=[
            self._bgm_sigma_phonk,
            self._bgm_skibidi_bounce,
            self._bgm_ohio_trap,
            self._bgm_rizz_wave,
            self._bgm_brainrot_bass,
