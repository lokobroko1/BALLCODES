            if p["life"]>0:
                sz=max(1,int(p["size"]*p["life"])); c=tuple(max(0,int(v*p["life"])) for v in p["color"])
                px,py=int(p["x"]),int(p["y"]); draw.ellipse([px-sz,py-sz,px+sz,py+sz],fill=c); surviving.append(p)
        self._death_particles=surviving

    def _update_and_render_bubbles(self, draw, img, frame):
        surviving=[]
        for b in self._bubble_particles:
            b["x"]+=b["vx"]; b["y"]+=b["vy"]; b["vy"]-=0.08; b["vx"]*=0.98; b["vy"]*=0.98
            b["life"]-=b["decay"]; b["wobble_phase"]+=b["wobble_speed"]
