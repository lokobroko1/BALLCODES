        song_fns[chosen_idx](audio,sr,race_start,race_end,rng_audio)
        # ─────────────────────────────────────────────────────────────────────

        death_thud_len=int(0.08*sr); death_thud_t=np.arange(death_thud_len,dtype=np.float64)/sr
        death_thud=np.sin(2*np.pi*45*death_thud_t)*np.exp(-death_thud_t*25)*0.3
        pop_len=int(0.06*sr); pop_t=np.arange(pop_len,dtype=np.float64)/sr
