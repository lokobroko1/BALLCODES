def _get_font(size: int):
    for path in [
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf",
    ]:
        if os.path.exists(path):
            try: return ImageFont.truetype(path, size)
            except Exception: continue
    return ImageFont.load_default()

_NOTO_EMOJI_FONT_PATH = "/content/NotoColorEmoji-Regular.ttf"
_NOTO_EMOJI_FONT_URL = (
    "https://github.com/googlefonts/noto-emoji/raw/main/fonts/NotoColorEmoji-Regular.ttf"
)

def _download_noto_emoji_font() -> bool:
    """Download NotoColorEmoji font if not already cached. Returns True on success."""
    if os.path.exists(_NOTO_EMOJI_FONT_PATH):
        return True
    try:
        r = requests.get(_NOTO_EMOJI_FONT_URL, timeout=30)
        if r.status_code == 200:
            with open(_NOTO_EMOJI_FONT_PATH, "wb") as f:
                f.write(r.content)
            return True
    except Exception:
        pass
    return False

_EMOJI_FONT_AVAILABLE = _download_noto_emoji_font()

def _get_emoji_font(size: int):
    """Load NotoColorEmoji at the given size, or fall back to the regular font."""
    if _EMOJI_FONT_AVAILABLE and os.path.exists(_NOTO_EMOJI_FONT_PATH):
        try:
            return ImageFont.truetype(_NOTO_EMOJI_FONT_PATH, size)
        except Exception:
            pass
    return _get_font(size)

_EMOJI_RE = re.compile(
    "[\U0001F300-\U0001FAFF"
    "\U00002600-\U000027BF"
    "\U0000FE00-\U0000FE0F"
    "\u2194-\u2199"
    "\u2300-\u23FF"
    "\u2B00-\u2BFF"
    "]+"
)

def _has_emoji(text: str) -> bool:
    """Return True if *text* contains any emoji characters."""
    return bool(_EMOJI_RE.search(text))

def _draw_text_centered(draw, text, font, cx, cy, fill, outline=(0, 0, 0)):
    if _has_emoji(text) and _EMOJI_FONT_AVAILABLE:
        try:
            emoji_font = _get_emoji_font(font.size)
        except AttributeError:
            # font.size unavailable (e.g. default bitmap font) — use a reasonable default
            emoji_font = _get_emoji_font(20)
        bbox = draw.textbbox((0, 0), text, font=emoji_font)
        tw, th = bbox[2]-bbox[0], bbox[3]-bbox[1]
        x, y = cx-tw//2, cy-th//2
        draw.text((x, y), text, font=emoji_font, fill=fill, embedded_color=True)
        return
    bbox = draw.textbbox((0, 0), text, font=font)
    tw, th = bbox[2]-bbox[0], bbox[3]-bbox[1]
    x, y = cx-tw//2, cy-th//2
    for dx in (-1,0,1):
        for dy in (-1,0,1):
            if dx or dy: draw.text((x+dx, y+dy), text, font=font, fill=outline)
    draw.text((x, y), text, font=font, fill=fill)

def _hsv(h, s, v, a=255):
    r, g, b = colorsys.hsv_to_rgb(h%1.0, s, v)
    return (int(r*255), int(g*255), int(b*255), a)

