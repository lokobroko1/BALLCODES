def _snapshot_hazards(hazards):
    return {
        "fireballs":[(fb.x,fb.y,fb.radius,fb.color,list(fb.trail)) for fb in hazards.fireballs],
        "spinning_lasers":[(sl.cx,sl.cy,sl.angle,sl.length,sl.thickness,sl.kill_radius,sl.color,sl.arms,sl.warmup_frames) for sl in hazards.spinning_lasers],
        "death_walls":[(dw.side,dw.position,dw.color,dw.warmup_frames,dw.retreating) for dw in hazards.death_walls],
        "shockwaves":[(sw.cx,sw.cy,sw.current_radius,sw.thickness,sw.color,sw.kill_thickness) for sw in hazards.shockwaves],
        "meteors":[(m_obj.target_x,m_obj.target_y,m_obj.current_y,m_obj.x,m_obj.radius,m_obj.blast_radius,m_obj.exploded,m_obj.explosion_frame,m_obj.current_blast_radius) for m_obj in hazards.meteors],
        "spikes":[(sp.x,sp.y,sp.radius,sp.pulse_phase,sp.warmup_frames) for sp in hazards.spikes],
