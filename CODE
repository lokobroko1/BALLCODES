def generate_vibrant_colors(n, rng):
    colors=[]
    for i in range(n):
        hue=(i/n+rng.uniform(-0.02,0.02))%1.0
        sat=rng.uniform(0.7,1.0); val=rng.uniform(0.75,1.0)
        r,g,b=colorsys.hsv_to_rgb(hue,sat,val)
        colors.append((int(r*255),int(g*255),int(b*255)))
    rng.shuffle(colors); return colors

