def discover_github_images(cache_dir="/content/github_avatars"):
    """
    Auto-discovers ALL .png images in the GitHub repo.
    Works with 001.png, 002.png, ... NNN.png
    No code changes needed when you add more images!
    Returns a list of PIL Images (RGBA, 160x160).
    """
    os.makedirs(cache_dir, exist_ok=True)
    images = []
    png_files = []

    # Step 1: Query GitHub API to list ALL files in the repo
    print(f"[*] Querying GitHub repo: {GITHUB_REPO_OWNER}/{GITHUB_REPO_NAME} ...")
    try:
        resp = requests.get(GITHUB_API_URL, timeout=15, headers={"Accept": "application/vnd.github.v3+json"})
        if resp.status_code == 200:
            contents = resp.json()
            for item in contents:
                if item.get("type") == "file" and item.get("name", "").lower().endswith(".png"):
                    png_files.append(item["name"])
            png_files.sort()
            print(f"[OK] Found {len(png_files)} PNG images in repo: {png_files}")
        else:
            print(f"[WARN] GitHub API returned {resp.status_code}. Trying fallback method...")
            png_files = _fallback_discover(cache_dir)
    except Exception as e:
        print(f"[WARN] GitHub API failed: {e}. Trying fallback method...")
        png_files = _fallback_discover(cache_dir)

    # Step 2: Download each image
    for fname in png_files:
        raw_url = f"{GITHUB_RAW_BASE}/{fname}"
        cache_path = os.path.join(cache_dir, fname)

        if os.path.exists(cache_path):
            try:
                img = Image.open(cache_path).convert("RGBA")
                img = img.resize((320, 320), Image.LANCZOS)
                images.append(img)
                print(f"  [CACHE] {fname}")
                continue
            except Exception:
                pass

        try:
            print(f"  [DOWNLOAD] {raw_url} ...")
            img_resp = requests.get(raw_url, timeout=20)
            if img_resp.status_code == 200:
                img_data = img_resp.content
                with open(cache_path, "wb") as f:
                    f.write(img_data)
                img = Image.open(io.BytesIO(img_data)).convert("RGBA")
                img = img.resize((320, 320), Image.LANCZOS)
                images.append(img)
                print(f"  [OK] {fname} ({len(img_data)//1024}KB)")
            else:
                print(f"  [SKIP] {fname} - HTTP {img_resp.status_code}")
        except Exception as e:
            print(f"  [ERROR] {fname}: {e}")

    print(f"[RESULT] Loaded {len(images)} custom images from GitHub.")
    return images

def _fallback_discover(cache_dir):
    """Fallback: try sequential filenames 001.png, 002.png, ... until 404."""
    found = []
    for i in range(1, 1001):
        fname = f"{i:03d}.png"
        raw_url = f"{GITHUB_RAW_BASE}/{fname}"
        try:
            resp = requests.head(raw_url, timeout=5)
            if resp.status_code == 200:
                found.append(fname)
            else:
                if len(found) > 0 and i > int(found[-1].replace(".png","")) + 5:
                    break
        except Exception:
            break
    print(f"[FALLBACK] Found {len(found)} images: {found}")
    return found

