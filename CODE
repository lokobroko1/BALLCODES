class BallBattleRoyale:
    def __init__(self, config=None):
        self.config=config or Config()
        self.rng=random.Random(self.config.seed)
        print(f"Seed: {self.config.seed}")

    def run(self):
        config=self.config; fps=config.fps
        max_frames=int(65*fps)
        countdown_dur=2.5
        winner_dur=5.0

        print(f"\n{'='*60}\n  BRAINROT BATTLE ROYALE - v6 CUSTOM + MEGA AVATAR EDITION\n  {len(BRAINROT_NAMES)} names | {len(_AVATAR_STYLES)} styles | GitHub auto-load\n{'='*60}\n")

        name_pool=list(BRAINROT_NAMES); self.rng.shuffle(name_pool)
        if len(name_pool) < config.num_balls:
            extra=list(BRAINROT_NAMES); self.rng.shuffle(extra)
            for i,n in enumerate(extra):
                if len(name_pool)>=config.num_balls: break
                name_pool.append(f"{n} #{i+2}")
        assigned_names=name_pool[:config.num_balls]
        assigned_chars=[{"name":n} for n in assigned_names]
        print(f"[*] Selected {len(assigned_names)} random names from {len(BRAINROT_NAMES)} pool.")

        print("[*] Loading avatars (GitHub custom + generated)...")
        character_images=generate_character_images(assigned_names, size=320, seed=config.seed)
        print(f"[OK] {len(character_images)} avatars ready.")

        available_categories: Set[str]=set()
        selected_challenges: List[Dict]=[]
        pool=list(ALL_CHALLENGES); self.rng.shuffle(pool)
        for ch in pool:
            if ch["category"] not in available_categories:
                selected_challenges.append(ch); available_categories.add(ch["category"])
            if len(selected_challenges)>=config.challenges_per_game: break
        if len(selected_challenges)<config.challenges_per_game:
            remaining=[c for c in pool if c not in selected_challenges]
            for c in remaining:
                selected_challenges.append(c)
                if len(selected_challenges)>=config.challenges_per_game: break
        self.rng.shuffle(selected_challenges)

        print("Challenges:")
        for i,ch in enumerate(selected_challenges): print(f"  {i+1}. {ch['emoji']} {ch['name']}")

        colors=generate_vibrant_colors(config.num_balls,self.rng)
        physics=PhysicsEngine(config,self.rng)
        arena_init=physics.get_arena(countdown_dur)
        ax1,ay1,ax2,ay2=arena_init

        balls: List[Ball]=[]
        cols,rows=10,10
        for i in range(config.num_balls):
            col=i%cols; row=i//cols; margin=config.ball_radius*2.5
            x=ax1+margin+col*((ax2-ax1-2*margin)/max(1,cols-1))
            y=ay1+margin+row*((ay2-ay1-2*margin)/max(1,rows-1))
            balls.append(Ball(i,x,y,config.ball_radius,colors[i],self.rng,assigned_chars[i]))

        hazards=HazardManager(config,self.rng)
        renderer=Renderer(config,character_images)

        print("Simulating...")
        frame_data: List[Dict]=[]
        winner: Optional[Ball]=None
        winner_detected_frame: int=-1
        forced_kill_timer=0
        death_times: List[float]=[]
        challenge_times: List[float]=[]

        race_duration=min(config.duration-countdown_dur-winner_dur, 50.0)
        interval=race_duration/max(1,len(selected_challenges))
        challenge_schedule: List[Tuple[float,int]]=[]
        for idx_s,ch in enumerate(selected_challenges):
            act_time=countdown_dur+interval*idx_s+self.rng.uniform(0.5,1.5)
            act_time=min(act_time,countdown_dur+race_duration-2)
            challenge_schedule.append((act_time,idx_s))
        challenge_schedule.sort(key=lambda x:x[0])
        next_challenge_ptr=0
        original_bounce=config.bounce_damping; original_margin=config.arena_margin_end

        active_challenge_windows: List[Tuple[int, int]] = []
        applied_challenge_indices: Set[int] = set()

        for frame in range(max_frames):
            t=frame/fps
            if winner_detected_frame>=0 and frame>=winner_detected_frame+int(winner_dur*fps): break
            if t<countdown_dur: phase="countdown"
            elif winner is not None: phase="winner"
            else: phase="racing"

            arena=physics.get_arena(t)

            active_challenge_windows = [
                (ci, ef) for ci, ef in active_challenge_windows if ef > frame
            ]
            active_challenge_indices: Set[int] = {ci for ci, ef in active_challenge_windows}

            if phase=="racing":
                while (next_challenge_ptr<len(challenge_schedule) and
                       t>=challenge_schedule[next_challenge_ptr][0]):
                    sched_time,sched_idx=challenge_schedule[next_challenge_ptr]
                    ch=selected_challenges[sched_idx]
                    try:
                        ch["apply"](balls=balls,arena=arena,hazards=hazards,
                                    rng=self.rng,config=config,frame=frame,renderer=renderer)
                    except Exception as e: print(f"Warning: {ch['name']}: {e}")

                    duration_f = CHALLENGE_ACTIVE_DURATIONS.get(ch["category"], 120)
                    active_challenge_windows.append((sched_idx, frame + duration_f))
                    applied_challenge_indices.add(sched_idx)
                    active_challenge_indices = {ci for ci, ef in active_challenge_windows if ef > frame}

                    renderer.set_challenge_banner(frame,ch["name"],ch["emoji"])
                    suf=random.choice(_EVENT_BRAINROT_SUFFIXES)
                    renderer.add_event_text(frame,f"{ch['emoji']} {ch['name']} {suf}",90)
                    renderer.trigger_screen_shake(8.0)
                    challenge_times.append(t)
                    print(f"  {ch['emoji']} {ch['name']} at t={t:.1f}s (active {duration_f} frames)")
                    next_challenge_ptr+=1

                hazards.update(t,frame,arena)
                physics.update_balls(balls,arena,hazards,frame)

                forced_kill_timer+=1
                kill_count_this_frame=0
                tracked_dead_ids: Set[int]=set()
                for ball in [b for b in balls if b.alive]:
                    died=hazards.check_ball_death(ball,frame,arena) or hazards.check_toxic_death(ball)
                    if died:
                        ball.alive=False; ball.death_frame=frame
                        renderer.add_death_particles(ball.x,ball.y,ball.color,frame)
                        renderer.add_bubble_explosion(ball.x,ball.y,ball.color,frame)
                        renderer.add_elimination(frame,ball.name,ball.color)
                        renderer.trigger_screen_shake(5.0)
                        death_times.append(t); forced_kill_timer=0; kill_count_this_frame+=1
                        tracked_dead_ids.add(ball.id)
                # Process immediate kills from challenge effects (scatter/implosion set death_frame=frame before hazard loop)
                for ball in balls:
                    if not ball.alive and ball.death_frame==frame and ball.id not in tracked_dead_ids:
                        renderer.add_bubble_explosion(ball.x,ball.y,ball.color,frame)
                        renderer.add_elimination(frame,ball.name,ball.color)
                        death_times.append(t); forced_kill_timer=0; kill_count_this_frame+=1
                if kill_count_this_frame>=3:
                    renderer.trigger_white_flash(3)
                    renderer.add_emoji_rain(min(25, kill_count_this_frame*5))

                alive_now=sum(1 for b in balls if b.alive)
                race_progress=max(0.001,(t-countdown_dur)/race_duration)

                if race_progress>0.40 and alive_now>20 and forced_kill_timer>fps*2:
                    ax1_a,ay1_a,ax2_a,ay2_a=arena
                    for _ in range(2):
                        angle_f=self.rng.uniform(0,2*math.pi)
                        hazards.fireballs.append(Fireball(
                            x=self.rng.uniform(ax1_a+30,ax2_a-30),
                            y=self.rng.uniform(ay1_a+30,ay2_a-30),
                            vx=math.cos(angle_f)*7,vy=math.sin(angle_f)*7,
                            radius=22,lifetime=12))
                    forced_kill_timer=0

                if race_progress>0.70 and alive_now>10 and forced_kill_timer>fps*1.5:
                    ax1_h,ay1_h,ax2_h,ay2_h=arena; cx_h,cy_h=(ax1_h+ax2_h)/2,(ay1_h+ay2_h)/2
                    arena_min=min(ax2_h-ax1_h,ay2_h-ay1_h)
                    hazards.shockwaves.append(Shockwave(
                        cx=cx_h,cy=cy_h,speed=9.0,
                        max_radius=arena_min*0.45,thickness=20,kill_thickness=20,
                        color=(255,100,200)))
                    forced_kill_timer=0

                alive_now=sum(1 for b in balls if b.alive)
                if alive_now<=1 and winner is None:
                    alive_list=[b for b in balls if b.alive]
                    if alive_list: winner=alive_list[0]
                    else:
                        last_dead=max(balls,key=lambda b:b.death_frame); last_dead.alive=True; winner=last_dead
                    winner_detected_frame=frame
                    print(f"WINNER: {winner.name} at t={t:.1f}s")
                alive_count=sum(1 for b in balls if b.alive)
            elif phase=="countdown": alive_count=config.num_balls
            else: alive_count=1

            snapshot={
                "t":t,"frame":frame,"phase":phase,"arena":arena,
                "alive_count":alive_count,
                "active_challenge_indices": set(active_challenge_indices),
                "applied_challenge_indices": set(applied_challenge_indices),
                "ball_states":[],"hazard_state":_snapshot_hazards(hazards)
            }
            for b in balls:
                snapshot["ball_states"].append({
                    "id":b.id,"x":b.x,"y":b.y,"vx":b.vx,"vy":b.vy,
                    "alive":b.alive,"color":b.color,"accent":b.accent,
                    "outline_color":b.outline_color,"trail":list(b.trail),
                    "invincible_timer":b.invincible_timer,"radius":b.radius})
            frame_data.append(snapshot)
            if frame%(fps*5)==0: print(f"  t={t:.1f}s alive={alive_count}")

        if winner is None:
            alive_list=[b for b in balls if b.alive]
            if alive_list: winner=alive_list[0]
            else: winner=max(balls,key=lambda b:b.death_frame); winner.alive=True
            winner_detected_frame=max(0,len(frame_data)-int(winner_dur*fps)-1)
            print(f"WINNER (cap): {winner.name}")

        actual_duration=len(frame_data)/fps
        winner_time=(winner_detected_frame/fps if winner_detected_frame>=0 else max(0.0,actual_duration-winner_dur))
        print(f"\nOK: {len(frame_data)} frames | {actual_duration:.1f}s total | {len(death_times)} deaths")
        gc.collect()
        config.bounce_damping=original_bounce; config.arena_margin_end=original_margin

        print("Generating audio...")
        audio_gen=AudioGenerator(config)
        audio_path=audio_gen.generate(actual_duration,winner.name,countdown_dur,
                                      death_times,challenge_times,winner_time)

        print("Encoding video...")
        frame_cache: Dict[int,np.ndarray]={}; cache_limit=3

        def make_frame(t_sec):
            f_idx=min(int(t_sec*fps),len(frame_data)-1)
            if f_idx in frame_cache: return frame_cache[f_idx]
            snap=frame_data[f_idx]
            for i_b,bs in enumerate(snap["ball_states"]):
                balls[i_b].x=bs["x"]; balls[i_b].y=bs["y"]
                balls[i_b].vx=bs["vx"]; balls[i_b].vy=bs["vy"]
                balls[i_b].alive=bs["alive"]; balls[i_b].trail=bs["trail"]
                balls[i_b].invincible_timer=bs["invincible_timer"]; balls[i_b].radius=bs["radius"]
            _restore_hazards(hazards,snap["hazard_state"])
            rendered=renderer.render_frame(
                snap["t"], snap["frame"], balls, snap["arena"], hazards,
                snap["alive_count"], config.num_balls,
                winner if snap["phase"]=="winner" else None,
                snap["phase"], selected_challenges,
                snap["active_challenge_indices"],
                snap["applied_challenge_indices"],
            )
            frame_cache[f_idx]=rendered
            if len(frame_cache)>cache_limit: oldest=min(frame_cache.keys()); del frame_cache[oldest]
            if f_idx%100==0 and f_idx>0: gc.collect()
            return rendered

        timestamp=time.strftime("%Y%m%d_%H%M%S")
        rand_suffix=''.join(random.choices('abcdefghijklmnopqrstuvwxyz0123456789',k=4))
        output_path=os.path.join(config.output_dir,f"brainrot_battle_{timestamp}_{rand_suffix}.mp4")

        video_clip=VideoClip(make_frame,duration=actual_duration).set_fps(fps)
        if audio_path and os.path.exists(audio_path):
            try:
                audio_clip=AudioFileClip(audio_path)
                if audio_clip.duration>actual_duration: audio_clip=audio_clip.subclip(0,actual_duration)
                video_clip=video_clip.set_audio(audio_clip); print("OK: Audio attached.")
            except Exception as e: print(f"Warning: Audio attach failed: {e}")

        video_clip.write_videofile(output_path,fps=fps,codec="libx264",bitrate=config.bitrate,
                                   audio_codec="aac",logger=None,threads=4)
        video_clip.close()
        file_mb=os.path.getsize(output_path)/(1024*1024)
        print(f"\nOK: Saved: {output_path} ({file_mb:.1f} MB)")
        audio_gen.cleanup(); frame_cache.clear(); gc.collect()
        return output_path

print("OK: Game orchestrator ready.")

