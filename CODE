            victory=(np.sin(2*np.pi*261.63*celeb_t)*0.18+np.sin(2*np.pi*329.63*celeb_t)*0.15+
                     np.sin(2*np.pi*392.00*celeb_t)*0.13+np.sin(2*np.pi*493.88*celeb_t)*0.10)
            self._safe_add(audio,celeb_start,victory*np.exp(-celeb_t*0.5),total_samples)
