            if life>0.7: cur_r=b["radius"]+(b["max_radius"]-b["radius"])*(1.0-life)/0.3
            elif life>0: cur_r=b["max_radius"]*(life/0.7)
            else: cur_r=0
            if life>0 and cur_r>1:
                bx_b=int(b["x"]+wobble); by_b=int(b["y"]); cr=max(1,int(cur_r))
                bf=tuple(min(255,c+40) for c in b["color"])
