def generate_avatar_pool(count=300, size=96, seed=42):
    """Generate a pool of procedural brainrot avatars."""
    rng = random.Random(seed)
    avatars = []
    for i in range(count):
        style_fn = rng.choice(_AVATAR_STYLES)
        try:
            av = style_fn(rng, size)
            if av.mode != "RGBA":
                av = av.convert("RGBA")
            avatars.append(av)
        except Exception:
            av = Image.new("RGBA", (size, size), (0,0,0,0))
            dr = ImageDraw.Draw(av)
            col = _hsv(rng.random(), 0.7, 0.85)
            dr.ellipse([0,0,size-1,size-1], fill=col)
            avatars.append(av)
    return avatars

