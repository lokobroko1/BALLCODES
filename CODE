def display_video(video_path):
    try:
        from IPython.display import HTML, display
        import base64
        if not os.path.exists(video_path): print(f"Not found: {video_path}"); return
        size_mb=os.path.getsize(video_path)/(1024*1024)
        if size_mb>50: print(f"Too large for inline ({size_mb:.1f}MB). Download: {video_path}"); return
        with open(video_path,'rb') as f: data=f.read()
        b64=base64.b64encode(data).decode('utf-8')
        html=f"""
        <div style="text-align:center; margin:20px 0;">
            <h3>BRAINROT BATTLE ROYALE - v6 CUSTOM + MEGA AVATAR EDITION</h3>
            <video width="360" height="640" controls autoplay loop
                   style="border-radius:12px; box-shadow:0 4px 20px rgba(0,0,0,0.3);">
                <source src="data:video/mp4;base64,{b64}" type="video/mp4">
            </video>
            <p style="color:#888; margin-top:8px;">{os.path.basename(video_path)} ({size_mb:.1f} MB)</p>
        </div>"""
        display(HTML(html))
    except ImportError: print(f"Video saved: {video_path}")
    except Exception as e: print(f"Display failed: {e} | Saved: {video_path}")


