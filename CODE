class PhysicsEngine:
    def __init__(self, config, rng=None):
        self.config=config; self.rng=rng if rng is not None else random.Random()

    def get_arena(self, t):
        progress=min(1.0,t/self.config.duration)
        ease=progress*progress
        margin=(self.config.arena_margin_start+
                (self.config.arena_margin_end-self.config.arena_margin_start)*ease)
        cx=self.config.width/2
        cy=self.config.height/2+40
        half_size=min(cx,cy)-margin
        half_size=max(half_size,50)
        x1=int(cx-half_size); y1=int(cy-half_size)
        x2=int(cx+half_size); y2=int(cy+half_size)
        return (x1,y1,x2,y2)

    def update_balls(self, balls, arena, hazards, frame):
        ax1,ay1,ax2,ay2=arena; dt=1.0/self.config.fps
        alive_balls=[b for b in balls if b.alive]
        frozen_ids=hazards.frozen_ball_ids if hasattr(hazards,'frozen_ball_ids') else set()
        hazards.update_toxic_exposure(balls)
        for ball in alive_balls:
            if ball.invincible_timer>0: ball.invincible_timer-=dt
            if ball.id in frozen_ids:
                ball.vx=0; ball.vy=0
                ball.trail.clear()
                continue
            hazards.apply_vortex_force(ball)
            ball.trail.append((ball.x,ball.y))
            if len(ball.trail)>8: ball.trail.pop(0)
            ball.x+=ball.vx; ball.y+=ball.vy
            ball.vx+=self.rng.gauss(0,0.08); ball.vy+=self.rng.gauss(0,0.08)
            speed=math.hypot(ball.vx,ball.vy)
            max_speed=12.0
            if speed>max_speed: ball.vx=ball.vx/speed*max_speed; ball.vy=ball.vy/speed*max_speed
            r=ball.radius
            if ball.x-r<ax1: ball.x=ax1+r; ball.vx=abs(ball.vx)*self.config.bounce_damping
            if ball.x+r>ax2: ball.x=ax2-r; ball.vx=-abs(ball.vx)*self.config.bounce_damping
            if ball.y-r<ay1: ball.y=ay1+r; ball.vy=abs(ball.vy)*self.config.bounce_damping
            if ball.y+r>ay2: ball.y=ay2-r; ball.vy=-abs(ball.vy)*self.config.bounce_damping
        self._ball_ball_collisions(alive_balls)

    def _ball_ball_collisions(self, balls):
        n=len(balls)
        for i in range(n):
            for j in range(i+1,n):
                b1,b2=balls[i],balls[j]
                dx=b2.x-b1.x; dy=b2.y-b1.y; dist=math.hypot(dx,dy)
                min_dist=b1.radius+b2.radius
                if dist<min_dist and dist>0.01:
                    nx=dx/dist; ny=dy/dist; overlap=min_dist-dist
                    b1.x-=nx*overlap*0.5; b1.y-=ny*overlap*0.5
                    b2.x+=nx*overlap*0.5; b2.y+=ny*overlap*0.5
                    dvx=b1.vx-b2.vx; dvy=b1.vy-b2.vy; dot=dvx*nx+dvy*ny
                    if dot>0:
                        b1.vx-=dot*nx*self.config.ball_ball_push; b1.vy-=dot*ny*self.config.ball_ball_push
                        b2.vx+=dot*nx*self.config.ball_ball_push; b2.vy+=dot*ny*self.config.ball_ball_push

print("OK: Physics engine ready.")

