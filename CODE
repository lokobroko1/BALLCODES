        pop_sound=np.sin(pop_phase)*np.exp(-pop_t*40)*0.15
        for dt_time in death_times:
            sample_pos=int(dt_time*sr)
            self._safe_add(audio,sample_pos,death_thud,total_samples)
            self._safe_add(audio,sample_pos+int(0.02*sr),pop_sound,total_samples)

        challenge_fanfare_len=int(0.3*sr); challenge_fanfare_t=np.arange(challenge_fanfare_len,dtype=np.float64)/sr
        challenge_fanfare=(np.sin(2*np.pi*440*challenge_fanfare_t)*0.15+
            np.sin(2*np.pi*554*challenge_fanfare_t)*0.12+np.sin(2*np.pi*659*challenge_fanfare_t)*0.10)
        fanfare_env=np.ones(challenge_fanfare_len,dtype=np.float64); fanfare_fade=max(1,challenge_fanfare_len//4)
        fanfare_env[-fanfare_fade:]=np.linspace(1,0,fanfare_fade); challenge_fanfare*=fanfare_env
        for ct_time in challenge_times: self._safe_add(audio,int(ct_time*sr),challenge_fanfare,total_samples)

        tension_start=race_start+int((race_end-race_start)*0.65)
        tension_len=race_end-tension_start
        if tension_len>0:
            ten_t=np.arange(tension_len,dtype=np.float64)/sr; progress_t=np.linspace(0.0,1.0,tension_len)
            freq_sweep=200.0+progress_t*800.0; phase_sweep=np.cumsum(freq_sweep/sr)*2*np.pi
            self._safe_add(audio,tension_start,np.sin(phase_sweep)*progress_t*0.05,total_samples)

        celeb_start=race_end; celeb_len=total_samples-celeb_start
        if celeb_len>0:
