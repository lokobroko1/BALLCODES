            cheer_t_arr=np.arange(cheer_len,dtype=np.float64)/sr; attack=min(int(0.1*sr),cheer_len)
            cheer_env=np.exp(-cheer_t_arr*0.6)
            if attack>0: cheer_env[:attack]=np.linspace(0,1,attack)
            self._safe_add(audio,celeb_start,cheer_noise*cheer_env*0.05,total_samples)

        tts_path=self._generate_tts(winner_name)
        if tts_path and os.path.exists(tts_path):
            try:
                tts_seg=AudioSegment.from_file(tts_path)
                tts_samples=np.array(tts_seg.get_array_of_samples(),dtype=np.float64)
                if tts_seg.channels==2: tts_samples=tts_samples[::2]
                tts_samples=tts_samples/32768.0*0.75
                if tts_seg.frame_rate!=sr:
                    ratio_tts=sr/tts_seg.frame_rate; new_len_tts=int(len(tts_samples)*ratio_tts)
                    tts_samples=np.interp(np.linspace(0,len(tts_samples)-1,new_len_tts),np.arange(len(tts_samples)),tts_samples)
                tts_start=celeb_start+int(0.8*sr); tts_end=min(tts_start+len(tts_samples),total_samples)
                actual_tts=tts_end-tts_start
                if actual_tts>0: audio[tts_start:tts_end]+=tts_samples[:actual_tts]
            except Exception as e: print(f"Warning: TTS load failed: {e}")

        max_val=np.max(np.abs(audio))
        if max_val>0: audio=audio/max_val*0.80
        audio_int16=(audio*32767).astype(np.int16)
        audio_path=os.path.join(self.temp_dir,"battle_audio.wav")
        with wave_mod.open(audio_path,'w') as wf:
            wf.setnchannels(1); wf.setsampwidth(2); wf.setframerate(sr); wf.writeframes(audio_int16.tobytes())
        print(f"OK: Audio generated: {audio_path}")
        return audio_path

    def _add_beep(self, audio, sr, time_s, freq=440, dur_ms=150, vol=0.5):
        n=int(sr*dur_ms/1000.0); t=np.arange(n,dtype=np.float64)/sr
        wave=np.sin(2*np.pi*freq*t)*vol; fade=max(1,int(n*0.1))
        env=np.ones(n,dtype=np.float64); env[:fade]=np.linspace(0,1,fade); env[-fade:]=np.linspace(1,0,fade)
        wave*=env; self._safe_add(audio,int(time_s*sr),wave,len(audio))

    @staticmethod
    def _safe_add(audio, start, data, total):
        if start<0: return
        end=min(start+len(data),total); actual=end-start
        if actual>0: audio[start:end]+=data[:actual]

    def _generate_tts(self, name):
        try:
            tts=gTTS(text=f"{name} wins! Last ball standing!",lang='en',slow=False)
            path=os.path.join(self.temp_dir,"winner_tts.mp3"); tts.save(path); return path
        except Exception as e: print(f"Warning: TTS failed: {e}"); return None

    def cleanup(self):
        for f in glob.glob(os.path.join(self.temp_dir,"*")):
            try: os.remove(f)
            except OSError: pass

