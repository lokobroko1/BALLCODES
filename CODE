    hazards.fireballs=[Fireball(x=x,y=y,radius=r,vx=0,vy=0,color=c,trail=list(tr)) for x,y,r,c,tr in snap["fireballs"]]
    hazards.spinning_lasers=[SpinningLaser(cx=cx,cy=cy,angle=a,length=ln,thickness=th,kill_radius=kr,color=c,arms=arm,warmup_frames=wf) for cx,cy,a,ln,th,kr,c,arm,wf in snap["spinning_lasers"]]
    hazards.death_walls=[DeathWall(side=s,position=p,color=c,warmup_frames=wf,retreating=ret) for s,p,c,wf,ret in snap["death_walls"]]
    hazards.shockwaves=[Shockwave(cx=cx,cy=cy,current_radius=cr,thickness=th,color=c,kill_thickness=kt) for cx,cy,cr,th,c,kt in snap["shockwaves"]]
