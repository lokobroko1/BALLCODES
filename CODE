    ax1,ay1,ax2,ay2=arena; cx,cy=(ax1+ax2)/2,(ay1+ay2)/2
    kill_radius=40
    renderer=kw.get("renderer"); frame=kw.get("frame",-1)
    for b in balls:
        if b.alive:
            dx,dy=b.x-cx,b.y-cy; dist=math.hypot(dx,dy)+0.01
            if dist < kill_radius and b.invincible_timer<=0:
                b.alive=False; b.death_frame=frame
                if renderer: renderer.add_death_particles(b.x,b.y,b.color,frame)
            else:
                force=rng.uniform(6,10)
                b.vx+=(dx/dist)*force; b.vy+=(dy/dist)*force

