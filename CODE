    print(f"\n[AVATAR SYSTEM] Preparing avatars for {len(names)} characters...")
    custom_images = discover_github_images()
    custom_count = len(custom_images)
    print(f"[AVATAR SYSTEM] {custom_count} custom images from GitHub")
    needed_generated = max(0, len(names) - custom_count)
    generated_count = max(needed_generated, len(names) // 2)
    print(f"[AVATAR SYSTEM] Generating {generated_count} procedural avatars...")
    avatar_seed = hash(seed) & 0xFFFFFF
    generated_images = generate_avatar_pool(generated_count, size, avatar_seed)
    all_images = list(custom_images) + list(generated_images)
    rng = random.Random(seed + 7)
    rng.shuffle(all_images)
    result = {}
    for i, name in enumerate(names):
